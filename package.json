{
  "name": "@aias/red-cliff-record",
  "version": "0.5.7",
  "license": "MIT",
  "author": {
    "name": "Nick Trombley",
    "email": "trombley.nick@gmail.com",
    "url": "https://nicktrombley.design"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Aias/red-cliff-record"
  },
  "bin": {
    "rcr": "./src/server/cli/rcr/index.ts"
  },
  "workspaces": [
    "packages/*",
    "."
  ],
  "type": "module",
  "scripts": {
    "build": "bun run stylegen && bunx --bun vite build",
    "check": "bun run lint && bun run typecheck && bun run format",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "bun run dev:panda & bun run dev:vite",
    "dev:full": "bun run --filter '*' dev:watch",
    "dev:panda": "panda --watch",
    "dev:vite": "bunx --bun vite",
    "dev:watch": "bunx --bun vite",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "rcr": "bun src/server/cli/rcr/index.ts",
    "start": "bun run server.ts",
    "stylegen": "rm -rf src/app/styled-system && panda codegen && panda cssgen",
    "typecheck": "tsgo --noEmit",
    "typecheck:watch": "tsgo --noEmit --watch"
  },
  "dependencies": {
    "@base-ui/react": "~1.5.0",
    "@libsql/client": "~0.17.3",
    "@octokit/request-error": "~7.1.0",
    "@octokit/rest": "~22.0.1",
    "@radix-ui/colors": "~3.0.0",
    "@radix-ui/react-slot": "~1.2.4",
    "@tailwindcss/vite": "~4.3.0",
    "@tanstack/react-form": "~1.33.0",
    "@tanstack/react-query": "~5.100.14",
    "@tanstack/react-router": "~1.170.10",
    "@tanstack/react-router-with-query": "~1.130.17",
    "@tanstack/react-start": "~1.168.18",
    "@trpc/client": "~11.17.0",
    "@trpc/react-query": "~11.17.0",
    "@trpc/server": "~11.17.0",
    "@types/bun": "~1.3.14",
    "airtable": "~0.12.2",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "cmdk": "~1.1.1",
    "colorjs.io": "~0.6.1",
    "dataloader": "~2.2.3",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "lucide-react": "~1.17.0",
    "markdown-it": "~14.2.0",
    "mime-types": "~3.0.2",
    "motion": "~12.40.0",
    "openai": "~6.39.1",
    "radix-ui": "~1.4.3",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "react-scan": "~0.5.7",
    "sonner": "~2.0.7",
    "superjson": "~2.2.6",
    "tailwind-merge": "~3.6.0",
    "vite": "~8.0.14",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@octokit/types": "~16.0.0",
    "@pandacss/dev": "~1.11.1",
    "@rolldown/plugin-babel": "~0.2.3",
    "@types/markdown-it": "~14.1.2",
    "@types/mime-types": "~3.0.1",
    "@types/node": "~25.9.1",
    "@types/react": "~19.2.15",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitejs/plugin-react": "~6.0.2",
    "babel-plugin-react-compiler": "~1.0.0",
    "drizzle-kit": "1.0.0-rc.4-5d5b77c",
    "oxfmt": "~0.52.0",
    "oxlint": "~1.67.0",
    "oxlint-tsgolint": "~0.23.0",
    "pg": "~8.21.0",
    "tailwindcss": "~4.3.0",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ]
}
