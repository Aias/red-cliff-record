{
  "name": "@aias/red-cliff-record",
  "version": "0.5.5",
  "license": "MIT",
  "author": {
    "name": "Nick Trombley",
    "email": "trombley.nick@gmail.com",
    "url": "https://nicktrombley.design"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Aias/red-cliff-record"
  },
  "bin": {
    "rcr": "./src/server/cli/rcr/index.ts"
  },
  "workspaces": [
    "packages/*",
    "."
  ],
  "type": "module",
  "scripts": {
    "build": "bun run stylegen && bunx --bun vite build",
    "check": "bun run lint && bun run typecheck && bun run format",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "bun run dev:panda & bun run dev:vite",
    "dev:full": "bun run --filter '*' dev:watch",
    "dev:panda": "panda --watch",
    "dev:vite": "bunx --bun vite",
    "dev:watch": "bunx --bun vite",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "rcr": "bun src/server/cli/rcr/index.ts",
    "start": "bun run server.ts",
    "stylegen": "rm -rf src/app/styled-system && panda codegen && panda cssgen",
    "typecheck": "tsgo --noEmit",
    "typecheck:watch": "tsgo --noEmit --watch"
  },
  "dependencies": {
    "@base-ui/react": "~1.4.1",
    "@libsql/client": "~0.17.3",
    "@octokit/request-error": "~7.1.0",
    "@octokit/rest": "~22.0.1",
    "@radix-ui/colors": "~3.0.0",
    "@radix-ui/react-slot": "~1.2.4",
    "@tailwindcss/typography": "~0.5.19",
    "@tailwindcss/vite": "~4.2.4",
    "@tanstack/react-form": "~1.29.1",
    "@tanstack/react-query": "~5.100.9",
    "@tanstack/react-router": "~1.169.1",
    "@tanstack/react-router-with-query": "~1.130.17",
    "@tanstack/react-start": "~1.167.61",
    "@trpc/client": "~11.17.0",
    "@trpc/react-query": "~11.17.0",
    "@trpc/server": "~11.17.0",
    "@types/bun": "~1.3.13",
    "airtable": "~0.12.2",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "cmdk": "~1.1.1",
    "colorjs.io": "~0.6.1",
    "dataloader": "~2.2.3",
    "drizzle-orm": "1.0.0-rc.1",
    "lucide-react": "~1.14.0",
    "markdown-it": "~14.1.1",
    "mime-types": "3.0.2",
    "motion": "~12.38.0",
    "openai": "~6.36.0",
    "radix-ui": "~1.4.3",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "react-scan": "~0.5.6",
    "sonner": "~2.0.7",
    "superjson": "~2.2.6",
    "tailwind-merge": "~3.5.0",
    "vite": "~8.0.10",
    "zod": "~4.4.2"
  },
  "devDependencies": {
    "@octokit/types": "~16.0.0",
    "@pandacss/dev": "~1.11.0",
    "@rolldown/plugin-babel": "~0.2.3",
    "@types/markdown-it": "~14.1.2",
    "@types/mime-types": "~3.0.1",
    "@types/node": "~25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260505.1",
    "@vitejs/plugin-react": "~6.0.1",
    "babel-plugin-react-compiler": "~1.0.0",
    "drizzle-kit": "1.0.0-rc.1",
    "oxfmt": "~0.47.0",
    "oxlint": "~1.62.0",
    "oxlint-tsgolint": "~0.22.1",
    "pg": "8.20.0",
    "tailwindcss": "~4.2.4",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ]
}
